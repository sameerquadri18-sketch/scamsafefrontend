dren:"Terms & Conditions"}),s.jsx("span",{children:"·"}),s.jsx(te,{to:"/",className:"hover:text-gray-400 transition-colors",children:"Home"})]})]})}function Kt({title:e,children:t}){return s.jsxs("div",{className:"glass-card p-4",children:[s.jsx("h2",{className:"text-sm font-bold text-white mb-2",children:e}),s.jsx("div",{className:"text-xs text-gray-400 leading-relaxed",children:t})]})}function OC(){return s.jsxs("div",{className:"flex flex-col gap-6 pb-8",children:[s.jsxs(P.div,{initial:{opacity:0,y:20},animate:{opacity:1,y:0},children:[s.jsxs(te,{to:"/",className:"flex items-center gap-2 text-xs text-gray-500 hover:text-white transition-colors mb-4",children:[s.jsx(jr,{size:14})," Back to Home"]}),s.jsxs("div",{className:"flex items-center gap-3 mb-2",children:[s.jsx(As,{size:24,className:"text-accent-orange"}),s.jsx("h1",{className:"text-2xl font-bold",children:"Terms & Conditions"})]}),s.jsx("p",{className:"text-xs text-gray-500",children:"Last updated: March 2026"})]}),s.jsxs(P.div,{initial:{opacity:0},animate:{opacity:1},transition:{delay:.1},className:"flex flex-col gap-5",children:[s.jsx(Nt,{title:"1. Acceptance",children:"These Terms of Service govern your use of ScamSafe (scamsafe.in), operated by Prodigious Digital Solutions, Hyderabad, Telangana, India. By using the service you agree to these terms. If you don't agree, please don't use the service."}),s.jsxs(Nt,{title:"2. Service Description",children:["ScamSafe provides:",s.jsxs("ul",{className:"list-disc pl-4 space-y-1 mt-1",children:[s.jsx("li",{children:"Free scan of 72+ Indian data broker databases using your phone number"}),s.jsx("li",{children:"OTP verification to confirm phone ownership and consent"}),s.jsx("li",{children:"DPDP Act 2023 legal removal notices sent to exposed databases"}),s.jsx("li",{children:"Automated opt-out form submissions to data brokers"}),s.jsx("li",{children:"Periodic rescans — monthly (Shield) or weekly (Shield Pro) for subscribed users"})]})]}),s.jsxs(Nt,{title:"3. User Consent",children:["By entering your phone number and verifying via OTP, you:",s.jsxs("ul",{className:"list-disc pl-4 space-y-1 mt-1",children:[s.jsx("li",{children:"Confirm you are the owner of the phone number"}),s.jsx("li",{children:"Authorize ScamSafe to scan databases on your behalf"}),s.jsx("li",{children:"Authorize us to send legal data deletion notices citing DPDP Act 2023"}),s.jsx("li",{children:"Consent to receiving OTP messages for verification"})]})]}),s.jsx(Nt,{title:"4. Free Scan",children:"The initial scan is free and requires no payment. You can see your exposure score, which databases have your data, and what types of data are exposed."}),s.jsx(Nt,{title:"5. Paid Services",children:"Data removal, continuous monitoring, and auto-rescan require a paid subscription. Pricing and payment options are available on the /pricing page."}),s.jsx(Nt,{title:"6. No Guarantee of Complete Removal",children:"While we have a high success rate, we cannot guarantee 100% removal from all databases. Data brokers may re-acquire your data from new sources. This is why continuous monitoring is recommended."}),s.jsx(Nt,{title:"7. DPDP Act Compliance",children:"All removal requests are made under Sections 12 and 13 of the Digital Personal Data Protection Act, 2023. Data brokers are legally required to comply within 7 business days. Non-compliance may attract penalties of up to ₹250 crore."}),s.jsxs(Nt,{title:"8. Limitation of Liability",children:["ScamSafe is not liable for:",s.jsxs("ul",{className:"list-disc pl-4 space-y-1 mt-1",children:[s.jsx("li",{children:"Data brokers failing to comply with legal removal notices"}),s.jsx("li",{children:"Delays in removal processing by third-party databases"}),s.jsx("li",{children:"Data reappearances from new sources after removal"}),s.jsx("li",{children:"Any damages arising from data exposure prior to using our service"})]})]}),s.jsx(Nt,{title:"9. Intellectual Property",children:"All content, code, and branding on scamsafe.in is owned by ScamSafe. You may not copy, modify, or redistribute any part of the service without written permission."}),s.jsx(Nt,{title:"10. Modifications",children:"We may update these terms at any time. Continued use after changes constitutes acceptance of the updated terms."}),s.jsx(Nt,{title:"11. Governing Law",children:"These terms are governed by the laws of India. Any disputes shall be subject to the jurisdiction of courts in India."}),s.jsxs(Nt,{title:"12. Contact",children:["For questions about these terms:",s.jsx("br",{}),s.jsx("strong",{children:"Email:"})," support@scamsafe.in",s.jsx("br",{}),s.jsx("strong",{children:"Website:"})," https://scamsafe.in"]})]}),s.jsxs("div",{className:"flex items-center gap-4 text-[10px] text-gray-600 justify-center pt-4",children:[s.jsx(te,{to:"/privacy",className:"hover:text-gray-400 transition-colors",children:"Privacy Policy"}),s.jsx("span",{children:"·"}),s.jsx(te,{to:"/terms",className:"text-accent-orange",children:"Terms & Conditions"}),s.jsx("span",{children:"·"}),s.jsx(te,{to:"/",className:"hover:text-gray-400 transition-colors",children:"Home"})]})]})}function Nt({title:e,children:t}){return s.jsxs("div",{className:"glass-card p-4",children:[s.jsx("h2",{className:"text-sm font-bold text-white mb-2",children:e}),s.jsx("div",{className:"text-xs text-gray-400 leading-relaxed",children:t})]})}const lh=[{id:101,category:"Scam Alert",date:"Mar 2026",title:"AI Voice Cloning Scams Surge: ₹800 Crore Lost in 3 Months",summary:"Scammers are using AI to clone voices of family members and colleagues, tricking victims into transferring money via UPI.",content:`A new wave of AI-powered voice cloning scams has hit India in early 2026, with losses exceeding ₹800 crore in just Q1. Scammers use publicly available voice samples from social media and WhatsApp to create realistic AI voice clones. They then call victims pretending to be a family member in distress or a boss requesting an urgent fund transfer.

Key findings:
• Over 4.5 lakh cases reported via 1930 helpline in Jan-Mar 2026
• Average loss per victim: ₹1.8 lakh
• Most targeted: senior citizens and working professionals
• Scammers source phone numbers from data broker databases

CERT-In has issued an advisory urging citizens to verify callers through a callback and never transfer money based on voice alone. The DPDP Act 2023 gives you the right to remove your phone number from data broker lists — reducing your exposure to such attacks.`,icon:xe,color:"text-accent-red"},{id:102,category:"Government Action",date:"Feb 2026",title:"DPDP Rules 2026 Notified: Data Brokers Now Face ₹250 Crore Penalty",summary:"The government has finally notified the DPDP Rules, making it mandatory for data brokers to comply with deletion requests within 72 hours.",content:`The Ministry of Electronics and Information Technology (MeitY) has notified the Digital Personal Data Protection Rules 2026, bringing the DPDP Act 2023 into full effect. Key highlights:

• Data brokers must respond to deletion requests within 72 hours
• Companies must appoint a Data Protection Officer (DPO)
• Consent managers must be registered with the Data Protection Board
• Non-compliance penalty: up to ₹250 crore per violation
• Citizens can file complaints directly with the Data Protection Board online

This is a landmark moment for digital privacy in India. ScamSafe leverages these provisions to send legally binding removal notices to data brokers, ensuring your personal data is deleted from their databases.`,icon:Zt,color:"text-accent-green"},{id:103,category:"Data Leak",date:"Jan 2026",title:"Telecom Data Breach: 8 Crore Jio & Airtel Users' Data Found on Dark Web",summary:"A massive telecom data dump containing names, phone numbers, Aadhaar details, and location data of 8 crore users was found on dark web forums.",content:`Security researchers discovered a massive database on dark web marketplaces containing personal data of approximately 8 crore Indian telecom subscribers from multiple carriers including Jio, Airtel, and Vi. The leaked data includes:

• Full names and addresses
• Phone numbers and alternate numbers
• Aadhaar and PAN numbers
• SIM activation dates and location data
• Recharge history and usage patterns

TRAI has launched an investigation and directed all telecom operators to conduct security audits. The breach is believed to have originated from a third-party vendor with access to telecom subscriber databases. This incident reinforces the importance of regularly scanning and removing your data from broker databases to minimize exposure.`,icon:xe,color:"text-accent-red"},{id:104,category:"Scam Alert",date:"Nov 2025",title:"Fake Aadhaar Update Scam: 15 Lakh Citizens Targeted via SMS",summary:'Scammers sent bulk SMS messages urging citizens to "update Aadhaar" through fake UIDAI websites, stealing biometric and financial data.',content:`A widespread phishing campaign targeted over 15 lakh Indians with fake SMS messages claiming their Aadhaar would be deactivated unless updated immediately. Victims were directed to convincing fake UIDAI websites that collected:

• Aadhaar numbers and OTPs
• Bank account details
• Fingerprint scans via phone cameras
• PAN and address information

The real UIDAI clarified that Aadhaar updates are only done through official channels (uidai.gov.in or Aadhaar centres). Police arrested 23 suspects across Gujarat, Rajasthan, and Jharkhand. The scammers had purchased phone number lists from data brokers to execute the bulk SMS campaign.`,icon:xe,color:"text-accent-red"},{id:1,category:"Scam Alert",date:"Feb 2025",title:"AIIMS Data Breach: 4 Crore Patient Records Leaked on Dark Web",summary:"In one of India's largest healthcare data breaches, AIIMS Delhi suffered a ransomware attack that exposed 4 crore patient records including Aadhaar numbers, medical histories, and contact details.",content:"The All India Institute of Medical Sciences (AIIMS) New Delhi was hit by a massive ransomware attack that crippled its servers for over two weeks. Hackers gained access to approximately 4 crore patient records containing sensitive information including Aadhaar numbers, addresses, phone numbers, and detailed medical histories. The data was reportedly listed for sale on dark web forums. The Indian Computer Emergency Response Team (CERT-In) was called in to investigate, and the incident highlighted the critical vulnerability of India's healthcare data infrastructure. The government subsequently issued new cybersecurity guidelines for all healthcare institutions.",icon:xe,color:"text-accent-red"},{id:2,category:"Government Action",date:"Jan 2025",title:"I4C Report: Indians Lost ₹22,812 Crore to Cyber Fraud in 2024",summary:"The Indian Cybercrime Coordination Centre (I4C) revealed that cyber fraud losses in India reached ₹22,812 crore in 2024, with 70,000+ victims daily.",content:`According to the Indian Cybercrime Coordination Centre (I4C) under the Ministry of Home Affairs, India witnessed an unprecedented surge in cybercrime in 2024. The total financial loss reached ₹22,812 crore, up 300% from 2021. The most common scam types included:

• Digital arrest scams (₹2,140 Cr)
• Trading/investment scams (₹4,636 Cr)
• Romance and dating scams (₹1,800 Cr)
• Phishing and OTP fraud (₹3,200 Cr)

The government has set up the 1930 helpline and the National Cybercrime Reporting Portal (cybercrime.gov.in) to help victims report fraud and freeze suspicious transactions within the golden hour.`,icon:Zt,color:"text-accent-orange"},{id:3,category:"Data Leak",date:"Dec 2024",title:"CoWIN Portal Data Leak: 150 Crore Indians' Vaccination Data Exposed",summary:"A Telegram bot was found serving personal data of Indian citizens from the CoWIN vaccination portal, including names, Aadhaar numbers, and passport details.",content:"A security researcher discovered a Telegram bot that was openly serving personal data from India's CoWIN vaccination portal. By entering a phone number, anyone could retrieve the registered person's name, Aadhaar number, passport number, date of birth, and vaccination details. The breach potentially affected over 150 crore registered users. The Ministry of Health initially denied the breach, but CERT-In later confirmed unauthorized access. The incident raised serious concerns about the security of India's digital public infrastructure and the need for stronger data protection measures under the DPDP Act 2023.",icon:xe,color:"text-accent-red"},{id:4,category:"Government Action",date:"Nov 2024",title:"DPDP Act 2023: India's Data Protection Law — What It Means for You",summary:"The Digital Personal Data Protection Act 2023 gives every Indian citizen the right to demand deletion of their personal data from any company.",content:`The Digital Personal Data Protection (DPDP) Act 2023, passed by the Indian Parliament, is India's first comprehensive data protection law. Key provisions:

• Right to Erasure (Section 12): You can demand any company delete your personal data
• Right to Correction (Section 13): You can ask companies to correct inaccurate data
• Consent Required (Section 6): Companies must get your explicit consent before collecting data
• Penalties: Non-compliance can result in fines up to ₹250 crore
• Data Protection Board: A new regulatory body will handle complaints

This law empowers Indian citizens to take control of their digital privacy. ScamSafe uses these provisions to send legal removal notices to data brokers on your behalf.`,icon:Zt,color:"text-accent-green"},{id:5,category:"Scam Alert",date:"Oct 2024",title:'"Digital Arrest" Scam: How Scammers Stole ₹2,140 Crore in 2024',summary:'Fraudsters impersonating police, CBI, and customs officers held victims under "digital arrest" via video calls, extorting thousands of crores.',content:`The "digital arrest" scam emerged as one of India's most devastating fraud types in 2024. Scammers would call victims claiming to be from police, CBI, customs, or the RBI, and allege that the victim's Aadhaar or phone number was linked to criminal activity. Victims were then placed under "digital arrest" — forced to stay on a video call for hours or days while transferring money to "clear their name."

Prime Minister Modi addressed this scam in his Mann Ki Baat broadcast, warning citizens that no government agency conducts arrests via video call. The MHA blocked over 6.69 lakh SIM cards and 1.32 lakh IMEIs used in such scams. The key protection: scammers can only target you if they have your phone number and personal data from data brokers.`,icon:xe,color:"text-accent-red"},{id:6,category:"Data Leak",date:"Sep 2024",title:"Star Health Insurance Data Breach: 3.1 Crore Customer Records Leaked",summary:"Star Health Insurance suffered a massive data breach exposing medical records, PAN, Aadhaar, and policy details of 3.1 crore customers via Telegram bots.",content:`Star Health and Allied Insurance Company, one of India's largest health insurers, confirmed a data breach affecting 3.1 crore customers. The stolen data included:

• Full names, addresses, phone numbers
• PAN and Aadhaar numbers
• Medical records and claim histories
• Policy details and payment information

The data was being distributed via Telegram bots and dark web forums. Star Health filed a lawsuit against Telegram to remove the bots. The incident highlighted how insurance companies store vast amounts of sensitive personal and medical data, making them prime targets for cybercriminals. IRDAI issued new cybersecurity guidelines for all insurance companies following this breach.`,icon:xe,color:"text-accent-red"},{id:7,category:"Government Action",date:"Aug 2024",title:"PM Modi Warns Against Cyber Scams in Mann Ki Baat",summary:"PM Modi dedicated a segment of Mann Ki Baat to educating citizens about digital arrest scams, phishing, and the importance of reporting cybercrime.",content:`In his monthly Mann Ki Baat radio broadcast, Prime Minister Narendra Modi addressed the growing menace of cyber fraud in India. Key points:

• "No government agency will ever threaten you on a phone or video call"
• Citizens should immediately report scams on the 1930 helpline
• The government has frozen ₹1,200 crore in fraudulent accounts through quick action
• CERT-In has blocked thousands of phishing websites targeting Indian citizens
• The I4C has trained 5,000+ police officers in cybercrime investigation

The PM urged citizens to spread awareness about common scams and reminded them that personal data protection is crucial in preventing these attacks.`,icon:se,color:"text-accent-purple"},{id:8,category:"Scam Alert",date:"Jul 2024",title:"Job Scam Epidemic: 10 Lakh Indians Duped via Fake WhatsApp Job Offers",summary:"Cybercriminals used data broker lists to send bulk WhatsApp messages offering fake work-from-home jobs, stealing ₹700+ crore from job seekers.",content:`A massive job scam operation was uncovered that had duped over 10 lakh Indians through fake WhatsApp job offers. The scammers purchased phone number databases from data brokers and sent bulk messages offering lucrative work-from-home jobs. Victims were asked to:

• Pay "registration fees" of ₹500-5,000
• Complete fake tasks (like, review, rate) for small payments
• Invest larger amounts for "premium tasks" with promised high returns

Once victims invested significant amounts, the scammers disappeared. The CBI arrested 45 people across multiple states and traced the operation to a Southeast Asian cyber fraud syndicate. The key enabler: data brokers who sell phone databases in bulk, allowing scammers to reach millions of potential victims.`,icon:xe,color:"text-accent-red"},{id:201,category:"Government Action",date:"Dec 2023",title:"DPDP Act 2023 Passed: India Finally Gets a Data Protection Law",summary:"After years of debate, India's Parliament passed the Digital Personal Data Protection Act 2023, giving citizens the right to erase their data from any company.",content:`The Indian Parliament passed the Digital Personal Data Protection (DPDP) Act 2023 on August 11, 2023, marking a historic milestone for digital privacy in India. After over five years of deliberation and multiple draft versions, India now has a comprehensive data protection framework.

Key provisions that protect you:
• Right to Erasure: Demand any company delete your personal data
• Right to Know: Companies must tell you what data they hold about you
• Mandatory Consent: No data collection without your explicit consent
• Child Protection: Special safeguards for minors' data
• Penalties up to ₹250 crore for violations

The Act empowers every Indian citizen to take control of their digital identity. ScamSafe was built on these principles — helping you exercise your legal right to remove personal data from data brokers and spam databases.`,icon:Zt,color:"text-accent-green"},{id:202,category:"Scam Alert",date:"Sep 2023",title:"KYC Fraud Wave: RBI Warns Against Fake Bank KYC Update Messages",summary:"The RBI issued an urgent advisory as fraudsters sent millions of fake KYC update SMS messages, stealing banking credentials of lakhs of Indians.",content:`The Reserve Bank of India (RBI) issued an urgent advisory warning citizens about a massive wave of fake KYC update scams. Fraudsters sent bulk SMS and WhatsApp messages claiming that victims' bank accounts would be frozen unless they completed KYC verification through a provided link.

How the scam worked:
• Victims received SMS: "Your account will be blocked. Update KYC now"
• The link led to a fake bank website that looked identical to the real one
• Victims entered their login credentials, debit card details, and OTPs
• Scammers immediately drained their accounts

Over 12 lakh complaints were filed on the 1930 helpline in September 2023 alone. The RBI clarified that banks never ask for KYC updates via SMS links. The scammers obtained phone numbers from data broker lists, enabling them to target millions of people simultaneously.`,icon:xe,color:"text-accent-red"},{id:203,category:"Data Leak",date:"Jun 2023",title:"MobiKwik Data Breach: 10 Crore Users' KYC Data Leaked Online",summary:"Fintech platform MobiKwik suffered a breach exposing KYC documents, Aadhaar cards, and financial data of 10 crore users on dark web forums.",content:`Digital payments platform MobiKwik faced allegations of a massive data breach affecting approximately 10 crore users. The leaked data reportedly included:

• Aadhaar card images and numbers
• PAN card details
• Phone numbers and email addresses
• KYC documents submitted during account verification
• Transaction histories

The 8.2 TB database was found on dark web forums with a searchable interface. While MobiKwik initially denied the breach, independent security researchers confirmed the authenticity of the data. This incident highlighted the risks of sharing KYC documents with fintech platforms and the importance of data minimization — sharing only what is absolutely necessary.`,icon:xe,color:"text-accent-red"}];function zC(){const[e,t]=h.useState(null),[n,r]=h.useState("all"),a=n==="all"?lh:lh.filter(i=>i.category===n);return s.jsxs("div",{className:"flex flex-col gap-6",children:[s.jsxs(P.div,{initial:{opacity:0,y:20},animate:{opacity:1,y:0},className:"text-center",children:[s.jsx("h1",{className:"text-2xl font-bold mb-2",children:"Scam Watch India"}),s.jsx("p",{className:"text-gray-400 text-sm",children:"Latest scams, data breaches & government actions to protect Indian citizens"})]}),s.jsx(P.div,{initial:{opacity:0,y:10},animate:{opacity:1,y:0},transition:{delay:.1},className:"flex gap-2 overflow-x-auto pb-1",children:["all","Scam Alert","Data Leak","Government Action"].map(i=>s.jsx("button",{onClick:()=>r(i),className:`px-3 py-1.5 rounded-lg text-xs font-medium whitespace-nowrap transition-all ${n===i?"bg-accent-orange/20 text-accent-orange border border-accent-orange/30":"bg-dark-card text-gray-500 border border-dark-border"}`,children:i==="all"?"All Posts":i},i))}),s.jsx("div",{className:"flex flex-col gap-3",children:a.map((i,o)=>{const l=i.icon,c=e===i.id;return s.jsxs(P.div,{initial:{opacity:0,y:20},animate:{opacity:1,y:0},transition:{delay:.1+o*.05},className:"glass-card overflow-hidden",children:[s.jsx("button",{onClick:()=>t(c?null:i.id),className:"w-full text-left p-4",children:s.jsxs("div",{className:"flex items-start gap-3",children:[s.jsx("div",{className:`w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 ${i.category==="Scam Alert"||i.category==="Data Leak"?"bg-accent-red/15":"bg-accent-green/15"}`,children:s.jsx(l,{size:16,className:i.color})}),s.j